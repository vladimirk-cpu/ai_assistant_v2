# AI Assistant Local Agent - пример файла переменных окружения
# Скопируй этот файл в .env и заполни свои значения

# API (OpenRouter или другой совместимый провайдер)
API_BASE_URL=https://openrouter.ai/api/v1
API_KEY=sk-or-v1-твой_реальный_ключ_здесь

# Модели для роутера и агентов
ROUTER_MODEL=deepseek/deepseek-chat
ARCHITECT_MODEL_REGULAR=deepseek/deepseek-v3.2
ARCHITECT_MODEL_COMPLEX=deepseek/deepseek-r1
CODE_MODEL=qwen/qwen3-coder
DEBUG_MODEL=qwen/qwen3.5-35b-a3b
REVIEW_MODEL=qwen/qwen3.5-35b-a3b

# Пути (можно не менять)
WORKSPACE_ROOT=%USERPROFILE%\AI-Assistant\workspace
MEMORY_BANK_PATH=%APPDATA%\AI-Assistant\memory-bank
LOGS_PATH=%APPDATA%\AI-Assistant\logs
